# DEXPulse — dev local (copier vers local.env)
# Sync : .\sync-local.ps1 → projets/dexpulse/backend/.env

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=Aria_ZHC_Bot
TELEGRAM_ADMIN_USERNAME=golderfarfr
TELEGRAM_ADMIN_IDS=
ACCESS_CODE_ENABLED=true
ARIA_AUTONOMOUS=true
ARIA_JUNO_OUTREACH=false
SITE_BASE_URL=http://localhost:5173
LLM_PROVIDER=ollama
# PC portable 8 Go VRAM (ex. RTX 5070 Laptop) : qwen2.5:14b — PAS 30B (freeze)
LLM_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://127.0.0.1:11434
ARIA_OLLAMA_NUM_CTX=8192
ARIA_X_HANDLE=Aria_ZHC
ARIA_LLM_ENABLED=true
ARIA_VECTOR_MEMORY=true
ARIA_DDG_SEARCH_CACHE=true
ARIA_MEMORY_ARBITRATOR=true

# ACP v2 — poll provider local (acp-cli + listener sur PC)
ARIA_ACP_PROVIDER_ENABLED=true
ARIA_ACP_EVENTS_FILE=%LOCALAPPDATA%\GoldenFar\acp-events.jsonl