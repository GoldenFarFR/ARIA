# DEXPulse — dev local (copier vers local.env)
# Sync : .\sync-local.ps1 → projets/dexpulse/backend/.env

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=Aria_ZHC_Bot
TELEGRAM_ADMIN_USERNAME=golderfarfr
TELEGRAM_ADMIN_IDS=5864967247
ACCESS_CODE_ENABLED=true
ARIA_AUTONOMOUS=true
ARIA_JUNO_OUTREACH=false
SITE_BASE_URL=http://localhost:5173
LLM_PROVIDER=ollama
# PC portable 8 Go VRAM (ex. RTX 5070 Laptop) : qwen2.5:14b — PAS 30B (freeze)
LLM_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://127.0.0.1:11434
ARIA_OLLAMA_NUM_CTX=8192
ARIA_X_HANDLE=Aria_ZHC
ARIA_LLM_ENABLED=true
DATA_DIR=%USERPROFILE%\GitHub-Repos\ARIA\vanguard\backend\data
ARIA_VECTOR_MEMORY=true
ARIA_DDG_SEARCH_CACHE=true
ARIA_MEMORY_ARBITRATOR=true

# ACP v2 — poll provider local (acp-cli + listener sur PC)
ARIA_ACP_PROVIDER_ENABLED=true
ARIA_ACP_EVENTS_FILE=%LOCALAPPDATA%\GoldenFar\acp-events.jsonl

# Autonomie revenu — boucle heartbeat sans relance operateur (start-aria-autonomous.ps1)
ARIA_REVENUE_AUTONOMY=true
ARIA_PROACTIVE_IDEAS=true
ARIA_AUTONOMY_CYCLE_MINUTES=360
ARIA_AUTONOMY_PROMO_HOURS=72
ARIA_AUTONOMY_INITIATIVE_HOURS=8

# Mode fondateur — shell opérateur (ouverte chez toi, publique reste grounded)
# Budget ~200$/sem : standard + Spark, pas de P(vrai) ni web épistémique ops
ARIA_OPERATOR_FOUNDER_MODE=true
ARIA_LLM_DEPTH_DEFAULT=standard
ARIA_SPARK_AGGRESSIVE=true
ARIA_EPISTEMIC_WEB_VERIFY=false
ARIA_EPISTEMIC_CRITIC=false
ARIA_LLM_COST_FOOTER=false
ARIA_LLM_MAX_TOKENS_STANDARD=700
ARIA_LLM_MAX_TOKENS_DEVELOP=1600